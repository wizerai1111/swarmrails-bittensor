# ── Coinbase CDP credentials ─────────────────────────────────────────────────
# Obtain from https://portal.cdp.coinbase.com → Access → API Keys

# Full API key identifier (organizations/<org-id>/apiKeys/<key-id>)
CDP_API_KEY_ID=organizations/your-org-id/apiKeys/your-key-id

# PKCS8 EC private key for API JWT signing (stored as \n-escaped single line)
CDP_API_KEY_SECRET="-----BEGIN PRIVATE KEY-----\nMIGH...\n-----END PRIVATE KEY-----\n"

# Wallet secret for transaction signing — create separately in the CDP portal
# under the same project; must be a base64-encoded PKCS8 EC DER key (~184 chars)
CDP_WALLET_SECRET=MIGHAgEAMBMGByqGSM49...your-wallet-secret-here

# ── Sweep destination ────────────────────────────────────────────────────────
# sweep_funds.js and sweep_burner.js send USDC here (your retail/custodial address)
RETAIL_ADDRESS=0xYourRetailAddressHere

# ── Supabase (Swarmrails gateway) ────────────────────────────────────────────
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
PAYMENT_RECIPIENT_ADDRESS="0xYourPaymentRecipientAddress"

# ── Other services ───────────────────────────────────────────────────────────
AGENT_PRIVATE_KEY="your-agent-private-key-hex"
OPENAI_API_KEY=sk-proj-...

# ── Optional: Jina AI (netuid 21 — web scraping) ────────────────────────────
# Without this key, Jina requests use the free unauthenticated tier (rate-limited).
# Get one at https://jina.ai — add it here to use the authenticated tier.
# JINA_API_KEY=jina_...
